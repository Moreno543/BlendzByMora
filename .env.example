# Local Netlify Dev — copy to .env and fill in, OR use `netlify link` + `netlify env:pull`
# Never commit .env (it is gitignored).

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Optional: set to true to skip sending SMS while testing other flows
# TWILIO_SMS_DISABLED=true

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: admin page (only if testing admin locally)
# ADMIN_DASHBOARD_TOKEN=
