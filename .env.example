# Local Netlify Dev — copy to .env and fill in, OR use `netlify link` + `netlify env:pull`
# Never commit .env (it is gitignored).

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: admin page (only if testing admin locally)
# ADMIN_DASHBOARD_TOKEN=

# Twilio SMS (see TWILIO_SETUP.md) — required on Netlify for booking SMS + reminders + YES replies
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGING_SERVICE_SID=   # MG… — recommended for A2P 10DLC (same Messaging Service as campaign)
# TWILIO_FROM_NUMBER=
# TWILIO_OWNER_NOTIFY_PHONE=
# TWILIO_SMS_DISABLED=true
